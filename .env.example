# ===========================================
# CHRISTLUMEN - Configuration Environment
# ===========================================

# ============== Django Settings ==============
SECRET_KEY=django-insecure-change-this-in-production
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# ============== URLs ==============
FRONTEND_URL=http://localhost:3000
API_URL=http://localhost:8000
WS_URL=ws://localhost:8000

# ============== Database ==============
# SQLite (Development - Default)
DATABASE_URL=sqlite:///db.sqlite3

# PostgreSQL (Production - Uncomment to use)
# DATABASE_URL=postgresql://user:password@localhost:5432/christlumen_db

# MySQL (Alternative - Uncomment to use)
# DATABASE_URL=mysql://user:password@localhost:3306/christlumen_db

# ============== Maintenance Mode ==============
# Enable/disable maintenance mode
MAINTENANCE_MODE=False
MAINTENANCE_MESSAGE=Application en maintenance. Veuillez réessayer plus tard.

# ============== WhatsApp Integration (Meta) ==============
# Get these from Meta Business Suite: https://business.facebook.com/

# New WhatsApp Configuration
WHATSAPP_ENABLED=False
WHATSAPP_API_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_API_VERSION=v18.0
WHATSAPP_TEMPLATE_NAME=
WHATSAPP_LANGUAGE=fr

# Legacy WhatsApp Configuration (Keep for backward compatibility)
META_PHONE_ID=
META_WHATSAPP_API_KEY=
META_WA_TOKEN=

# ============== OTP Settings ==============
# OTP expiration time in seconds (default: 5 minutes)
OTP_EXPIRATION_SECONDS=300

# Cooldown before sending another OTP (default: 1 minute)
OTP_SEND_COOLDOWN_SECONDS=60

# ============== Nexaah SMS API ==============
# SMS notification service configuration
NEXAAH_SMS_ENABLED=False
NEXAAH_BASE_URL=https://api.nexaah.net
NEXAAH_SEND_ENDPOINT=/send
NEXAAH_CREDITS_ENDPOINT=/credits
NEXAAH_USER=
NEXAAH_PASSWORD=
NEXAAH_SENDER_ID=Christlumen

# ============== Notification Preferences ==============
# Default notification channel: whatsapp, sms, email
DEFAULT_NOTIFICATION_CHANNEL=whatsapp

# ============== Email Settings (Optional) ==============
# EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
# EMAIL_HOST=smtp.gmail.com
# EMAIL_PORT=587
# EMAIL_USE_TLS=True
# EMAIL_HOST_USER=your-email@gmail.com
# EMAIL_HOST_PASSWORD=your-app-password

# ============== AWS S3 Storage (Optional) ==============
# For production file storage
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_STORAGE_BUCKET_NAME=christlumen-media
# AWS_S3_REGION_NAME=us-east-1

# ============== Redis (Optional) ==============
# For caching and Channels layer in production
# REDIS_URL=redis://localhost:6379/0

# ============== Sentry (Optional) ==============
# For error tracking in production
# SENTRY_DSN=

# ============== Social Auth (Optional) ==============
# GOOGLE_OAUTH2_CLIENT_ID=
# GOOGLE_OAUTH2_CLIENT_SECRET=
# FACEBOOK_APP_ID=
# FACEBOOK_APP_SECRET=

# ============== Payment Gateways ==============

# FreeMoPay Payment Gateway
FREEMOPAY_ENABLED=False
FREEMOPAY_BASE_URL=https://api.freemopay.com
FREEMOPAY_APP_KEY=
FREEMOPAY_SECRET_KEY=
FREEMOPAY_CALLBACK_URL=http://localhost:8000/api/payments/freemopay/callback
# Timeouts in seconds
FREEMOPAY_INIT_PAYMENT_TIMEOUT=60
FREEMOPAY_STATUS_CHECK_TIMEOUT=30
FREEMOPAY_TOKEN_TIMEOUT=60
# Token cache duration in seconds (default 1 hour)
FREEMOPAY_TOKEN_CACHE_DURATION=3600
# Retry configuration
FREEMOPAY_MAX_RETRIES=3
FREEMOPAY_RETRY_DELAY=1.0

# Stripe (Optional)
# STRIPE_PUBLIC_KEY=
# STRIPE_SECRET_KEY=

# PayPal (Optional)
# PAYPAL_CLIENT_ID=
# PAYPAL_CLIENT_SECRET=

# ============== Other Settings ==============
# CORS_ALLOWED_ORIGINS=http://localhost:3000,https://christlumen.com
# SECURE_SSL_REDIRECT=False
# SESSION_COOKIE_SECURE=False
# CSRF_COOKIE_SECURE=False
